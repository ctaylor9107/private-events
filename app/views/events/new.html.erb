<h1>New Event<h2>

<%= form_with model: @event do |form| %>
    <div>
        <%= form.label :name %><br>
        <%= form.text_field :name %>
    </div>

    <div>
        <%= form.label :location %><br>
        <%= form.text_field :location %><br>
    </div>

    <div>
        <%= form.label :date %><br>
        <%= form.date_field :date %><br>
    </div>

    <div>
        <%= form.time_select :time %>
    </div>

    <div>
        <%= form.submit %>
    </div>
<% end %>